# Box base image: the disposable workspace the agent runs in. Needs git (for the
# two-payload seed: clone bundle + stash apply + untar) and the runclave binary
# (for in-box helpers). The AGENT CLI itself (claude/copilot/…) is installed on
# top per policy-pack — this base is agent-agnostic (adapter model).
FROM golang:1.26-alpine AS build
WORKDIR /src
COPY go.mod go.sum* ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -trimpath -ldflags="-s -w -buildid=" -o /runclave ./cmd/runclave

FROM alpine:3.20
RUN apk add --no-cache git ca-certificates && adduser -D -u 10001 runclave \
    && mkdir -p /seed /run/runclave && chown 10001:10001 /seed /run/runclave
COPY --from=build /runclave /usr/local/bin/runclave
USER 10001
WORKDIR /home/runclave
# The lifecycle execs the agent via `docker exec`; the container just idles.
CMD ["sleep", "infinity"]
